{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev -- --port $PORT"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && .venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT --reload"],
      "port": 8001,
      "autoPort": false
    }
    ,{
      "name": "diagram",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3099", "."],
      "port": 3099
    }
  ]
}
